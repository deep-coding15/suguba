# ─── Docker Compose (racine) ─────────────────────────────────────────────────

# URLs des frontends vues depuis le navigateur (utilisées lors du build)
CLIENT_VITE_API_URL=http://TON_IP_VPS:8000 
ADMIN_VITE_API_URL=http://TON_IP_VPS:8000

# MongoDB local (inutile si tu utilises Atlas)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_MOI

# ─── server/.env ─────────────────────────────────────────────────────────────

PORT=8000

# MongoDB local :
MONGODB_URI=mongodb://admin:CHANGE_MOI@mongo:27017/suguba?authSource=admin
# MongoDB Atlas (remplace la ligne ci-dessus) :
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/suguba

# JWT
SECRET_KEY_ACCESS_TOKEN=CHANGE_MOI_64_CHARS
SECRET_KEY_REFRESH_TOKEN=CHANGE_MOI_64_CHARS
JSON_WEB_TOKEN_SECRET_KEY=CHANGE_MOI_64_CHARS

# Cloudinary
cloudinary_Config_Cloud_Name=ton_cloud_name
cloudinary_Config_api_key=ton_api_key
cloudinary_Config_api_secret=ton_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=ton_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ton_client_secret
GOOGLE_CALLBACK_URL=http://TON_IP_VPS:8000/api/user/auth/google/callback

# URL du frontend client (Google OAuth redirect + CORS)
CLIENT_URL=http://TON_IP_VPS:3000

# CORS – origines autorisées (séparées par virgule, sans espace)
ALLOWED_ORIGINS=http://TON_IP_VPS:3000,http://TON_IP_VPS:3001

# Email (nodemailer)
EMAIL=ton@email.com
EMAIL_PASS=ton_mot_de_passe_app

# Resend (si utilisé)
RESEND_API_KEY=re_xxxxxxxxxxxx
